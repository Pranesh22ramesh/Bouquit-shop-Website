generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL")
  directUrl = env("DIRECT_URL")
}

model User {
  id                  String               @id @default(uuid())
  fullName            String
  email               String               @unique
  phoneNumber         String?
  passwordHash        String
  role                Role                 @default(USER)
  isActive            Boolean              @default(true)
  createdAt           DateTime             @default(now())
  updatedAt           DateTime             @updatedAt
  address             String?
  activities          ActivityLog[]
  cartItems           CartItem[]
  likes               Like[]
  orders              Order[]
  passwordResetTokens PasswordResetToken[]
  refreshTokens       RefreshToken[]
  reviews             Review[]
  wishlistItems       WishlistItem[]
}

model RefreshToken {
  id        String    @id @default(uuid())
  tokenHash String    @unique
  expiresAt DateTime
  revokedAt DateTime?
  createdAt DateTime  @default(now())
  userId    String
  user      User      @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model PasswordResetToken {
  id        String   @id @default(uuid())
  tokenHash String   @unique
  expiresAt DateTime
  createdAt DateTime @default(now())
  userId    String
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model Like {
  id        String   @id @default(uuid())
  productId String
  createdAt DateTime @default(now())
  userId    String
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([userId, productId])
}

model WishlistItem {
  id              String   @id @default(uuid())
  productId       String
  productSnapshot Json?
  createdAt       DateTime @default(now())
  userId          String
  user            User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([userId, productId])
}

model CartItem {
  id              String   @id @default(uuid())
  productId       String
  quantity        Int      @default(1)
  customization   Json?
  productSnapshot Json?
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt
  userId          String
  user            User     @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model Order {
  id              String      @id @default(uuid())
  status          OrderStatus @default(PENDING)
  paymentMethod   String
  itemsPrice      Decimal     @db.Decimal(10, 2)
  taxPrice        Decimal     @db.Decimal(10, 2)
  shippingPrice   Decimal     @db.Decimal(10, 2)
  totalPrice      Decimal     @db.Decimal(10, 2)
  shippingAddress Json
  orderItems      Json
  createdAt       DateTime    @default(now())
  updatedAt       DateTime    @updatedAt
  userId          String
  deliveryDate    DateTime?
  user            User        @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model Review {
  id        String   @id @default(uuid())
  productId String?
  userName  String
  rating    Int
  comment   String
  image     String?
  isHidden  Boolean  @default(false)
  isPinned  Boolean  @default(false)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  userId    String
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model ActivityLog {
  id           String   @id @default(uuid())
  action       String
  resourceType String?
  resourceId   String?
  details      Json?
  createdAt    DateTime @default(now())
  userId       String
  user         User     @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model ContentSection {
  id        String   @id @default(uuid())
  key       String   @unique
  data      Json
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model Product {
  id                  String       @id @default(uuid())
  name                String
  category            String
  price               Decimal      @db.Decimal(10, 2)
  offerPrice          Decimal?     @db.Decimal(10, 2)
  description         String       @default("")
  image               String?
  badge               ProductBadge @default(NORMAL)
  availability        Availability @default(AVAILABLE)
  featured            Boolean      @default(false)
  customizedAvailable Boolean      @default(true)
  createdAt           DateTime     @default(now())
  updatedAt           DateTime     @updatedAt
}

model SeoConfig {
  id                    String   @id @default(uuid())
  businessName          String   @default("MIDHUNYAS Petals")
  businessSlogan        String   @default("Karur's Finest Flower Shop")
  address               String   @default("Karur, Tamil Nadu, India")
  city                  String   @default("Karur")
  state                 String   @default("Tamil Nadu")
  country               String   @default("India")
  postalCode            String   @default("639001")
  phone                 String   @default("+91 9942071721")
  whatsapp              String   @default("+91 9942071721")
  email                 String   @default("miudhunyas2012karur@gmail.com")
  latitude              String   @default("10.9601")
  longitude             String   @default("78.0766")
  googleMapsUrl         String   @default("")
  businessHours         Json?
  logoUrl               String   @default("")
  faviconUrl            String   @default("")
  defaultOgImage        String   @default("")
  ga4MeasurementId      String   @default("")
  gtmContainerId        String   @default("")
  gscVerificationCode   String   @default("")
  bingVerificationCode  String   @default("")
  facebookAppId         String   @default("")
  instagramUrl          String   @default("")
  facebookUrl           String   @default("")
  twitterHandle         String   @default("")
  siteUrl               String   @default("https://karurflowershop.vercel.app")
  robotsCustomRules     String   @default("")
  createdAt             DateTime @default(now())
  updatedAt             DateTime @updatedAt
}

model SeoPage {
  id               String   @id @default(uuid())
  pageKey          String   @unique
  pageTitle        String
  metaTitle        String
  metaDescription  String
  keywords         String   @default("")
  canonicalUrl     String   @default("")
  robots           String   @default("index, follow")
  ogTitle          String   @default("")
  ogDescription    String   @default("")
  ogImage          String   @default("")
  twitterTitle     String   @default("")
  twitterDescription String @default("")
  twitterImage     String   @default("")
  schemaType       String   @default("WebPage")
  customJsonLd     String   @default("")
  isActive         Boolean  @default(true)
  createdAt        DateTime @default(now())
  updatedAt        DateTime @updatedAt
}

enum Role {
  USER
  SUBADMIN
  ADMIN
}

enum ProductBadge {
  NORMAL
  NEW_ARRIVAL
  OFFER
}

enum Availability {
  AVAILABLE
  UNAVAILABLE
}

enum OrderStatus {
  PENDING
  PROCESSING
  DELIVERED
  CANCELLED
}
